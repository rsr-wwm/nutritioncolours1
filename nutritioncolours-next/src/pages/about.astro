---
import SectionHeading from '../components/SectionHeading.astro';
import SharedSections from '../components/SharedSections.astro';
import Icons from '../components/Icons.astro';
import { ABOUT_FAQS } from '../data/constants';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Our Approach & Philosophy | NutritionColours" description="Learn about our root-cause medical nutrition protocols led by clinical nutritionist Dr. Shilpa Thakur.">
  <div class="p-6 md:p-10 max-w-7xl mx-auto space-y-24">
    <div class="space-y-16">
      <SectionHeading subtitle="Philosophy" title="Our Approach" isMain={true} />
      <div class="max-w-4xl space-y-6">
        <div class="space-y-6 text-lg text-stone-600 leading-relaxed font-medium">
          <div class="p-10 bg-emerald-50 rounded-[40px] border border-emerald-100 shadow-sm">
            <h2 class="text-3xl font-black text-emerald-950 brand-font mb-4">The Modern Health Crisis</h2>
            <p class="text-lg text-stone-600 leading-relaxed">In a world where lifestyle disorders like obesity, thyroid dysfunction, diabetes, and PCOD are normalized, conventional medicine often focuses on symptom management. At NutritionColours, we assert that true healing requires a root-cause approach that addresses the foundational triggers of disease.</p>
          </div>
          <p class="px-4">Our bedrock belief is that most diseases begin in the kitchen, and therefore, the first and most effective medicine should be sourced from the kitchen. We blend ancient Ayurvedic wisdom with modern nutritional science to help you heal naturally.</p>
        </div>
      </div>
    </div>

    <div class="space-y-16">
      <SectionHeading subtitle="Service Excellence" title="The Four Pillars of Healing" isMain={false} />
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { title: 'Root-Cause Focused Healing', desc: 'We go beyond symptom management to reverse diseases from their roots using whole plant-based foods.', icon: 'leaf' },
          { title: 'Personalised Medical Nutrition', desc: 'Exhaustively customized protocols based on your specific medical diagnosis, lifestyle, and biochemical imbalances.', icon: 'file-text' },
          { title: 'Lifestyle Disorders Reversal', desc: 'Directly addressing systemic issues like insulin resistance and chronic inflammation through functional nutrition.', icon: 'check' },
          { title: 'Education & Empowerment', desc: 'Providing the tools to understand your body, moving far beyond simply handed-out diet charts.', icon: 'search' }
        ].map((pillar) => (
          <div class="bg-white p-10 rounded-[40px] border border-stone-100 shadow-lg hover:shadow-2xl transition-all group flex flex-col items-center text-center">
            <div class="w-20 h-20 rounded-3xl bg-emerald-50 flex items-center justify-center text-emerald-600 mb-8 group-hover:bg-emerald-600 group-hover:text-white transition-all duration-500">
              <Icons name={pillar.icon} size={32} />
            </div>
            <h3 class="text-xl font-black text-emerald-950 mb-4 brand-font leading-tight">{pillar.title}</h3>
            <p class="text-stone-500 text-sm leading-relaxed">{pillar.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-emerald-950 rounded-[64px] p-12 md:p-24 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 w-96 h-96 bg-lime-400/10 rounded-full blur-[100px]" aria-hidden="true"></div>
      <div class="relative z-10 max-w-4xl mx-auto space-y-8">
        <span class="text-lime-400 font-black uppercase tracking-[0.4em] text-[10px]">Our Vision</span>
        <h2 class="text-4xl md:text-6xl font-black text-white brand-font leading-tight">Sparking a Food-as-Medicine Revolution</h2>
        <p class="text-emerald-100/70 text-lg md:text-xl leading-relaxed">To educate the world that food is chemistry, therapy, and pure biological energy. We aim to reduce dependency on long-term medications and make natural, sustainable healing accessible to every home.</p>
        <div class="flex flex-wrap justify-center gap-6 pt-8">
          <a href="/plans" class="bg-lime-400 text-emerald-950 px-10 py-5 rounded-2xl font-black uppercase tracking-widest text-xs hover:bg-lime-300 transition-all">Start Your Journey</a>
          <a href="/contact" class="bg-white/10 backdrop-blur-md text-white border border-white/20 px-10 py-5 rounded-2xl font-black uppercase tracking-widest text-xs hover:bg-white/20 transition-all">Speak to an Expert</a>
        </div>
      </div>
    </div>

    <SharedSections type="faq" faqData={ABOUT_FAQS} faqTitle="Philosophy FAQs" />
  </div>
</BaseLayout>
