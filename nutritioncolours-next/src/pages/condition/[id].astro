---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ClinicalConditionDetail } from '../../components/ClinicalDetails';
import { MEDICAL_CONDITIONS_DATA, HERBS_SPICES_DATA } from '../../lib/clinical_databases';

export async function getStaticPaths() {
  return MEDICAL_CONDITIONS_DATA.map((cond) => ({
    params: { id: cond.id },
    props: { cond },
  }));
}

const { cond } = Astro.props;
---

<BaseLayout
  title={`${cond.name} - Reversal Protocol | NutritionColours`}
  description={cond.rootCause}
  keywords={[cond.name, ...(cond.seoKeywords || [])]}
>
  <ClinicalConditionDetail client:load cond={cond} herbsData={HERBS_SPICES_DATA} />
</BaseLayout>
