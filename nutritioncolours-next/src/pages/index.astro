---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icons from '../components/Icons.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SharedSections from '../components/SharedSections.astro';
import { HeroSlider } from '../components/ui/HeroSlider.tsx';
import { BANNERS, PLANS, TESTIMONIALS, TEAM, HOW_IT_WORKS, HOME_FAQS } from '../data/constants';
import { TOPICS } from '../data/topics';
import { RECIPES } from '../data/recipes';

const topicsData = TOPICS;
---

<BaseLayout
  title="NutritionColours | Metabolic Health & Circadian Nutrition Reversal"
  description="Clinical Metabolic Reversal practice led by Dr. Shilpa Thakur, Ph.D. Reversing Type 2 Diabetes, PCOS, and Fatty Liver via evidence-based circadian nutrition systems."
>
  <div class="space-y-4 pb-8">
    {/* Stateful React island loaded client-side */}
    <div class="relative">
      <HeroSlider client:load banners={BANNERS} />
    </div>

    {/* Philosophy Statement */}
    <div class="max-w-4xl mx-auto px-6 py-12 text-center gsap-reveal-fade">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 text-emerald-700 text-xs font-black uppercase tracking-[0.2em] border border-emerald-100 mb-6" aria-hidden="true">
        <Icons name="check" size={12} /> Science-Based &bull; Holistic &bull; Clinical
      </div>
      <h2 class="text-3xl md:text-5xl font-black text-emerald-950 brand-font italic leading-tight">&quot;Most diseases begin in the kitchen, and the first medicine should also come from the kitchen.&quot;</h2>
      <p class="mt-8 text-stone-600 font-black uppercase tracking-widest text-sm">- Dr. Shilpa Thakur, Ph.D.</p>
    </div>

    {/* Founder Feature block */}
    <div class="max-w-7xl mx-auto px-6 gsap-reveal-slide">
      <div class="bg-white rounded-[40px] shadow-2xl shadow-emerald-900/5 border border-stone-100 overflow-hidden relative group">
        <div class="grid md:grid-cols-12 gap-0">
          <div class="md:col-span-5 relative h-[300px] md:h-auto overflow-hidden bg-stone-100">
            <div class="absolute inset-0 w-full h-full overflow-hidden transform group-hover:scale-105 transition-transform duration-[3000ms]">
              <img src={TEAM[0].image} loading="eager" width="699" height="525" class="w-full h-full object-cover object-top" alt="Dr. Shilpa Thakur" referrerpolicy="no-referrer" />
            </div>
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-stone-900/10 to-transparent" aria-hidden="true"></div>
          </div>
          <div class="md:col-span-7 p-6 md:p-8 lg:p-10 flex flex-col justify-center space-y-4 bg-stone-50/30">
            <div class="space-y-3">
              <span class="text-emerald-700 font-black uppercase tracking-[0.3em] text-xs bg-emerald-50 px-4 py-1 rounded-full border border-emerald-100 inline-block">Medical Nutritionist | Founder</span>
              <h2 class="text-4xl md:text-5xl font-black text-emerald-950 brand-font leading-tight tracking-tighter">Root-Cause Focused Healing</h2>
              <div class="flex items-center gap-2 px-3 py-1 bg-emerald-100/50 rounded-lg w-fit">
                <Icons name="check" size={14} class="text-emerald-600" />
                <span class="text-[10px] font-black text-emerald-900 uppercase tracking-widest">{TEAM[0].details}</span>
              </div>
            </div>
            <div class="prose prose-stone max-w-none">
              <p class="text-lg md:text-xl text-stone-700 leading-relaxed font-bold italic border-l-4 border-lime-400 pl-8 py-2">&quot;Your kitchen is the ultimate hospital. We just provide the clinical manual for metabolic recovery.&quot;</p>
              <p class="text-stone-600 text-sm md:text-base leading-relaxed mt-6 font-medium">Dr. Shilpa Thakur holds a Ph.D. in Clinical Nutrition and operates as a world-class Metabolic Researcher and Clinical Nutrition Specialist (Non-Medical Practitioner). With over a decade of research experience, she specializes in the design of circadian food protocols and metabolic nutrition systems that optimize chronic wellness and support cellular health by blending ancient Ayurvedic principles with modern nutritional biology.</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-6 pt-6 border-t border-stone-200">
              <a href="/team/shilpa" class="bg-emerald-900 text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-emerald-800 transition-all flex items-center justify-center gap-3 group shadow-xl shadow-emerald-900/10">
                Meet Dr. Shilpa Thakur 
                <Icons name="arrow-right" size={16} class="group-hover:translate-x-1 transition-transform" />
              </a>
              <div class="flex items-center justify-center sm:justify-start gap-6 py-2 sm:py-0 sm:px-8 text-stone-500 border-t sm:border-t-0 sm:border-l border-stone-200 sm:border-stone-300 ml-0 sm:ml-4">
                <a href={TEAM[0].socials?.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-emerald-700 transition-colors" aria-label="LinkedIn">
                  <Icons name="linkedin" size={24} />
                </a>
                <a href={TEAM[0].socials?.instagram} target="_blank" rel="noopener noreferrer" class="hover:text-emerald-700 transition-colors" aria-label="Instagram">
                  <Icons name="instagram" size={24} />
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* The Healing Process */}
    <div class="max-w-7xl mx-auto px-6 py-12">
      <SectionHeading subtitle="Success Path" title="The Healing Process" />
      <div class="grid md:grid-cols-4 gap-8">
        {HOW_IT_WORKS.map((item, i) => (
          <div class="relative bg-white p-10 rounded-[32px] shadow-lg shadow-emerald-900/5 border border-stone-100 hover:shadow-2xl hover:border-emerald-100 transition-all group overflow-hidden">
            <svg aria-hidden="true" class="absolute top-0 right-0 w-32 h-24 -mr-4 -mt-4 group-hover:scale-110 transition-transform select-none pointer-events-none" viewBox="0 0 100 80">
              <text x="100" y="70" text-anchor="end" font-size="72" font-weight="900" fill="none" stroke="rgba(4, 120, 87, 0.1)" stroke-width="1.5">0{i+1}</text>
            </svg>
            <div class="relative z-10 w-16 h-16 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 mb-8 group-hover:bg-emerald-600 group-hover:text-white transition-all duration-500">
              {item.icon === 'Search' && <Icons name="search" size={32} />}
              {item.icon === 'FileText' && <Icons name="file-text" size={32} />}
              {item.icon === 'Leaf' && <Icons name="leaf" size={32} />}
              {item.icon === 'Check' && <Icons name="check" size={32} />}
            </div>
            <h3 class="relative z-10 text-xl font-black text-emerald-950 mb-3 group-hover:text-emerald-700 transition-colors uppercase tracking-tight">{item.title}</h3>
            <p class="relative z-10 text-stone-500 leading-relaxed text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Our Programs */}
    <div class="bg-stone-50 py-24 text-emerald-950 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none" aria-hidden="true">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(#10b981_1px,transparent_1px)] [background-size:40px_40px]"></div>
      </div>
      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <SectionHeading subtitle="Clinical Care" title="Our Programs" isMain={false} />
        <div class="grid md:grid-cols-3 gap-8">
          {PLANS.map((p) => {
            const iconName = p.id === 'plan-1' ? 'leaf' : p.id === 'plan-2' ? 'wand' : 'lock';
            return (
              <div class="bg-white rounded-[40px] shadow-xl border border-stone-100 hover:border-emerald-500 hover:shadow-2xl transition-all group p-10 flex flex-col h-full">
                <div class="w-16 h-16 rounded-2xl bg-emerald-50 flex items-center justify-center text-emerald-600 mb-8 font-black">
                  <Icons name={iconName} size={32} />
                </div>
                <span class="text-xs font-black uppercase tracking-widest text-emerald-800 mb-2 block">{p.idealFor}</span>
                <h3 class="text-2xl font-black mb-4 brand-font text-emerald-950">{p.name}</h3>
                <p class="text-stone-600 text-sm mb-8 leading-relaxed line-clamp-3 font-medium">{p.description}</p>
                <a href="/plans" class="w-full py-4 rounded-2xl bg-emerald-900 text-white font-bold uppercase tracking-widest text-xs hover:bg-emerald-800 transition-colors mt-auto flex items-center justify-center gap-3 text-center block">
                  View Protocol <Icons name="arrow-right" size={14} class="inline-block ml-1" />
                </a>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    {/* Clinical Diagnosis Hub */}
    <div class="max-w-7xl mx-auto px-6 py-12 border-t border-stone-100">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6">
        <div>
          <span class="text-xs font-black text-emerald-800 uppercase tracking-[0.4em] mb-2 block">Protocol Library</span>
          <h2 class="text-4xl md:text-5xl font-black text-emerald-950 brand-font tracking-tight">Clinical Diagnosis Hub</h2>
        </div>
        <a href="/knowledge/health-topics" class="bg-emerald-50 text-emerald-700 px-6 py-3 rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-emerald-100 transition-all flex items-center justify-center">Explore All Clinical Health Topics</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {topicsData.slice(0, 12).map((topic) => (
          <a href={`/topic/${topic.id}`} class="bg-white border border-stone-100 p-6 rounded-3xl hover:border-emerald-200 hover:shadow-xl transition-all cursor-pointer group flex flex-col h-full block">
            <div class="w-10 h-10 rounded-xl bg-stone-50 flex items-center justify-center text-emerald-600 mb-4 group-hover:bg-emerald-600 group-hover:text-white transition-all">
              <Icons name="flask" size={18} />
            </div>
            <h3 class="text-xs font-black text-emerald-950 uppercase tracking-tight leading-tight group-hover:text-emerald-700 transition-colors mb-2">{topic.title}</h3>
            <p class="text-xs text-stone-600 font-bold uppercase tracking-widest mt-auto">{topic.category}</p>
          </a>
        ))}
      </div>
    </div>

    {/* Success Stories */}
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <div class="w-8 h-px bg-emerald-500"></div>
            <span class="text-emerald-800 font-black uppercase tracking-widest text-xs">Proof of Concept</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-black text-emerald-950 brand-font mt-2">Life Transformed</h2>
        </div>
        <a href="/testimonials" class="px-8 py-3 bg-stone-100 text-stone-600 rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-emerald-50 hover:text-emerald-700 transition-all flex items-center justify-center">Read All Patient Success Stories</a>
      </div>
      <div class="hidden md:grid md:grid-cols-3 gap-8">
        {TESTIMONIALS.map((t) => (
          <div class="bg-white p-10 rounded-[32px] shadow-sm border border-stone-100 hover:shadow-xl transition-all relative">
            <div aria-hidden="true" class="text-5xl text-emerald-100 font-serif absolute top-6 left-6 -z-0 opacity-50">&quot;</div>
            <div class="relative z-10">
              <p class="text-stone-600 italic leading-relaxed text-sm mb-8">&quot;{t.text}&quot;</p>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 border border-emerald-100 shadow-sm">
                  <Icons name="user" size={20} />
                </div>
                <div>
                  <div class="font-bold text-emerald-950 text-sm">{t.name}</div>
                  <span class="text-xs uppercase font-black text-emerald-800 tracking-widest">{t.condition}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      {/* Mobile view fallback: CSS horizontal flex wrapper */}
      <div class="flex gap-6 overflow-x-auto pb-6 md:hidden scrollbar-none snap-x snap-mandatory">
        {TESTIMONIALS.map((t) => (
          <div class="bg-white p-8 rounded-[32px] shadow-sm border border-stone-100 min-w-[280px] max-w-[320px] snap-center shrink-0">
            <p class="text-stone-600 italic leading-relaxed text-sm mb-6 line-clamp-4">&quot;{t.text}&quot;</p>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 border border-emerald-100">
                <Icons name="user" size={16} />
              </div>
              <div>
                <div class="font-bold text-emerald-950 text-xs">{t.name}</div>
                <span class="text-[9px] uppercase font-black text-emerald-800 tracking-widest">{t.condition}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Clinical Recipes */}
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-8 mt-12">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <div class="w-8 h-px bg-emerald-500"></div>
            <span class="text-xs font-black uppercase tracking-widest text-emerald-800">Kitchen Laboratory</span>
          </div>
          <h2 class="text-3xl md:text-5xl font-black text-emerald-950 brand-font tracking-tight">Clinical Recipes</h2>
        </div>
        <a href="/recipes" class="text-xs font-black text-emerald-800 border-b-2 border-emerald-200 pb-1 hover:border-emerald-500 transition-all">View All Healing Recipes</a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {RECIPES.slice(0, 4).map((recipe) => (
          <a href={`/recipe/${recipe.id}`} class="group flex flex-col bg-white rounded-2xl p-6 border border-stone-100 hover:shadow-xl transition-all duration-300 text-left block">
            <div>
              <div class="flex justify-between items-start mb-3">
                <span class="text-[10px] font-black text-emerald-800 uppercase tracking-widest">{recipe.category}</span>
                <div class="flex gap-1">
                  {recipe.tags.slice(0, 1).map((tag: string) => (
                    <span class="text-[10px] font-bold text-stone-600 border border-stone-200 px-2 rounded-sm">{tag}</span>
                  ))}
                </div>
              </div>
              <h3 class="text-base font-black text-emerald-950 brand-font leading-tight group-hover:text-emerald-700 transition-colors uppercase tracking-tight line-clamp-2 mb-2">{recipe.title}</h3>
              <div class="flex items-center gap-2 text-xs font-bold text-stone-600 uppercase tracking-widest">
                <Icons name="utensils" size={12} class="text-emerald-500" />
                <span>{recipe.prepTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    {/* Core Plans Mini-CTA */}
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-3 gap-6">
        {BANNERS.map((banner) => (
          <a href="/plans" class="group flex flex-col justify-center items-center text-center rounded-3xl bg-emerald-950 p-10 cursor-pointer shadow-sm hover:shadow-lg border border-white/5 transition-all duration-300 relative overflow-hidden block">
            <div class="absolute inset-0 opacity-5 pointer-events-none bg-[radial-gradient(#10b981_1px,transparent_1px)] [background-size:20px_20px]" aria-hidden="true"></div>
            <div class="relative z-10 w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-lime-400 mb-6 group-hover:bg-lime-400 group-hover:text-emerald-950 transition-all duration-500">
              <Icons name="flask" size={24} />
            </div>
            <h3 class="relative z-10 text-xl font-black mb-2 text-white brand-font leading-tight">{banner.title}</h3>
            <p class="relative z-10 text-emerald-400 text-[10px] uppercase tracking-widest font-black">{banner.subtitle}</p>
          </a>
        ))}
      </div>
    </div>

    {/* Digital Tribe Social Links */}
    <div class="max-w-7xl mx-auto px-6 pb-24">
      <div class="text-center mb-12">
        <span class="text-emerald-700 font-black uppercase tracking-[0.3em] text-xs">Global Community</span>
        <h2 class="text-3xl md:text-5xl font-black text-emerald-950 brand-font mt-2">Join Our Digital Tribe</h2>
        <p class="text-stone-500 max-w-2xl mx-auto mt-4 text-sm leading-relaxed">Clinical wisdom for everyone. Join over <strong>100,000+</strong> wellness seekers.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        {[
          { name: 'linkedin', bg: 'bg-[#005c8e]', label: 'LinkedIn' },
          { name: 'facebook', bg: 'bg-[#165bb4]', label: 'Facebook' },
          { name: 'instagram', bg: 'bg-gradient-to-tr from-[#96126d] via-[#b3143c] to-[#d66511]', label: 'Instagram' },
          { name: 'youtube', bg: 'bg-[#c00000]', label: 'YouTube' },
          { name: 'twitter', bg: 'bg-black', label: 'Twitter' },
          { name: 'quora', bg: 'bg-[#96201c]', label: 'Quora' }
        ].map((social) => (
          <a href="/connect" class={`${social.bg} text-white p-8 rounded-[40px] shadow-lg group hover:scale-[1.05] transition-all duration-300 flex flex-col items-center justify-center gap-4 w-full text-center block`}>
            <Icons name={social.name} size={32} class="group-hover:scale-110 transition-transform" />
            <span class="text-[10px] font-black uppercase tracking-[0.2em]">{social.label}</span>
          </a>
        ))}
      </div>
    </div>

    {/* FAQs Section */}
    <SharedSections type="faq" faqData={HOME_FAQS} faqTitle="NutritionColours Basics" />
  </div>

  {/* Client animations handling for GSAP and Lenis setup */}
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    
    gsap.registerPlugin(ScrollTrigger);

    // Fade-in animations for section headings and titles
    gsap.from('.gsap-reveal-fade', {
      opacity: 0,
      y: 30,
      duration: 1,
      stagger: 0.2,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '.gsap-reveal-fade',
        start: 'top 85%',
        toggleActions: 'play none none none'
      }
    });

    // Slide reveals
    gsap.from('.gsap-reveal-slide', {
      opacity: 0,
      x: -50,
      duration: 1.2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '.gsap-reveal-slide',
        start: 'top 80%',
        toggleActions: 'play none none none'
      }
    });
  </script>
</BaseLayout>
