---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArticleClientPage } from '../../app/article/[id]/ArticleClientPage';
import { BLOG_ARTICLES } from '../../lib/constants';

export async function getStaticPaths() {
  return BLOG_ARTICLES.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<BaseLayout
  title={`${article.title} | NutritionColours`}
  description={article.title}
  keywords={[article.category, "Metabolic Article", article.title]}
>
  <ArticleClientPage client:load articleId={article.id} />
</BaseLayout>
