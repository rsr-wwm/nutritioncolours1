---
import Icons from '../components/Icons.astro';
import SharedSections from '../components/SharedSections.astro';
import AnimatedVisual from '../components/AnimatedVisual.astro';
import { PLANS, PLANS_FAQS } from '../data/constants';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Clinical Healing Programs | NutritionColours" description="Explore Dr. Shilpa Thakur's clinical nutrition programs for Diabetes, PCOS, Fatty Liver, and metabolic wellness.">
  <div class="space-y-0">
    <div class="relative w-full min-h-[500px] lg:h-[70vh] bg-emerald-950 overflow-hidden flex items-center px-6">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-[radial-gradient(#10b981_1px,transparent_1px)] [background-size:48px_48px] opacity-10" aria-hidden="true"></div>
        <AnimatedVisual type="catalog" />
        <div class="absolute inset-0 bg-gradient-to-r from-emerald-950 via-emerald-950/90 to-emerald-950/40" aria-hidden="true"></div>
        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-emerald-950 to-transparent" aria-hidden="true"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto w-full grid lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8">
          <div class="inline-flex items-center gap-3 px-6 py-2 rounded-full bg-lime-400/10 border border-lime-400/20 text-lime-400 text-xs font-black uppercase tracking-[0.5em]">
            <Icons name="flask" size={16} /> Precision Protocol
          </div>
          <div class="space-y-6">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white brand-font leading-[0.9] tracking-tighter">Clinical <span class="text-lime-400 italic">Healing</span> Systems</h1>
            <div class="w-24 h-1.5 bg-lime-400 rounded-full" aria-hidden="true"></div>
          </div>
          <p class="text-emerald-50/80 text-xl md:text-2xl font-bold italic leading-relaxed border-l-4 border-lime-400 pl-8 max-w-2xl">Evidence-based metabolic protocols designed to achieve clinical remission through physician-led nutritional science.</p>
          <div class="flex flex-wrap gap-6 pt-4">
            <div class="flex items-center gap-3 text-white/40 text-[10px] font-black uppercase tracking-widest">
              <Icons name="check" size={14} class="text-lime-400" /> Bio-Individual
            </div>
            <div class="flex items-center gap-3 text-white/40 text-[10px] font-black uppercase tracking-widest">
              <Icons name="check" size={14} class="text-lime-400" /> Circadian Rhythm Aligned
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-24 space-y-24">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {PLANS.map((plan) => {
          const slug = plan.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
          return (
            <div class="bg-white rounded-[40px] border border-stone-100 p-8 shadow-lg hover:shadow-2xl transition-all duration-300 flex flex-col justify-between group relative overflow-hidden">
              <div class="absolute -top-12 -right-12 w-32 h-32 bg-emerald-50 rounded-full group-hover:scale-150 transition-transform duration-500 opacity-50" aria-hidden="true"></div>
              <div class="space-y-6 relative z-10">
                <div class="w-14 h-14 rounded-2xl bg-emerald-50 text-emerald-700 flex items-center justify-center font-bold">
                  <Icons name={plan.icon} size={28} />
                </div>
                <div class="space-y-2">
                  <span class="text-[9px] font-black tracking-widest text-emerald-800 uppercase bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">{plan.duration}</span>
                  <h3 class="text-2xl font-black text-emerald-950 brand-font leading-tight pt-2">{plan.name}</h3>
                </div>
                <p class="text-stone-500 text-sm leading-relaxed">{plan.description}</p>
                <div class="space-y-2 pt-2">
                  <span class="text-[10px] font-black text-emerald-900 tracking-wider uppercase block">Focus Metrics:</span>
                  <ul class="space-y-1.5 text-xs text-stone-600 font-semibold uppercase tracking-wide">
                    {plan.features.slice(0, 3).map((f) => (
                      <li class="flex items-center gap-2">
                        <Icons name="check" size={12} class="text-lime-500" />
                        <span>{f}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
              <div class="pt-8 relative z-10">
                <a href={`/plans/${slug}`} class="w-full py-4 rounded-2xl font-black uppercase tracking-[0.15em] text-xs transition-all bg-stone-50 text-emerald-900 border border-stone-200 hover:border-emerald-200 hover:bg-emerald-50 text-center block">View Full Protocol</a>
              </div>
            </div>
          );
        })}
      </div>
      <div class="mt-12 bg-gradient-to-r from-emerald-900 to-emerald-950 rounded-[32px] text-white p-8 md:p-12 shadow-xl relative overflow-hidden border border-emerald-800 flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="absolute top-0 right-0 w-64 h-64 bg-lime-400 opacity-5 rounded-full blur-3xl" aria-hidden="true"></div>
        <div class="space-y-4 max-w-2xl relative z-10">
          <span class="text-[10px] font-black text-lime-400 bg-lime-400/10 px-3 py-1 rounded-full border border-lime-400/25 tracking-widest uppercase inline-block">2026 Circadian Reset Challenge</span>
          <h3 class="text-3xl font-black brand-font leading-tight">Is your daily routine holding back your metabolic recovery?</h3>
          <p class="text-emerald-100/70 text-sm leading-relaxed">Aligning meal times, sleep hygiene, and light cycles with natural biological clocks reduces systemic insulin resistance and cellular stress.</p>
        </div>
        <a href="/tools" class="shrink-0 bg-lime-400 hover:bg-lime-300 text-emerald-950 font-black uppercase tracking-widest text-xs px-8 py-5 rounded-2xl transition-all shadow-lg hover:scale-105 active:scale-95 duration-200 cursor-pointer text-center block">Start Rhythm Audit</a>
      </div>
      <SharedSections type="disclaimer" />
      <SharedSections type="faq" faqData={PLANS_FAQS} faqTitle="Program FAQs" />
    </div>
  </div>
</BaseLayout>
