---
interface Props {
  type: string;
}

const { type } = Astro.props;
const isPlan1 = type === 'plan-1';
const isPlan2 = type === 'plan-2';
const isPlan3 = type === 'plan-3';
---

<div class="absolute inset-0 overflow-hidden pointer-events-none">
  <div class="absolute inset-0 bg-emerald-950"></div>
  <div class="absolute inset-0 opacity-10">
    <svg aria-hidden="true" width="100%" height="100%" class="w-full h-full text-emerald-500">
      <pattern id="gridLarge" width="100" height="100" patternUnits="userSpaceOnUse">
        <path d="M 100 0 L 0 0 0 100" fill="none" stroke="currentColor" stroke-width="0.5" />
      </pattern>
      <rect width="100%" height="100%" fill="url(#gridLarge)" />
    </svg>
  </div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(163,230,53,0.05)_1px,transparent_1px)] bg-[size:40px_40px] opacity-20"></div>
  
  <div class="absolute right-0 top-0 w-1/2 h-full hidden lg:flex items-center justify-center opacity-30">
    {isPlan1 && (
      <div class="relative w-[500px] h-[500px]">
        <svg aria-hidden="true" viewBox="0 0 200 200" class="w-full h-full text-lime-400">
          <circle cx="100" cy="100" r="40" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 8" class="animate-spin" style="animation-duration: 30s;" />
          <circle cx="100" cy="100" r="65" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 8" class="animate-spin" style="animation-direction: reverse; animation-duration: 40s;" />
          <circle cx="100" cy="100" r="90" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 8" class="animate-spin" style="animation-duration: 60s;" />
          <path d="M100 20 L100 180 M20 100 L180 100" stroke="currentColor" stroke-width="0.2" class="opacity-50" />
        </svg>
      </div>
    )}
    
    {isPlan2 && (
      <div class="relative w-[450px] h-[450px]">
        <svg aria-hidden="true" viewBox="0 0 200 200" class="w-full h-full text-emerald-400">
          <path d="M40 100 Q100 20 160 100 T280 100" fill="none" stroke="currentColor" stroke-width="0.5" class="opacity-50" />
          <circle cx="100" cy="100" r="70" fill="none" stroke="currentColor" stroke-width="0.2" stroke-dasharray="1 4" class="animate-spin" style="animation-duration: 60s;" />
        </svg>
      </div>
    )}
    
    {isPlan3 && (
      <div class="relative w-[400px] h-[400px]">
        <svg aria-hidden="true" viewBox="0 0 200 200" class="w-full h-full text-teal-400">
          <line x1="40" y1="40" x2="40" y2="160" stroke="currentColor" stroke-width="2" class="animate-pulse" />
          <line x1="80" y1="40" x2="80" y2="160" stroke="currentColor" stroke-width="2" class="animate-pulse" style="animation-delay: 2s;" />
          <line x1="120" y1="40" x2="120" y2="160" stroke="currentColor" stroke-width="2" class="animate-pulse" style="animation-delay: 4s;" />
          <line x1="160" y1="40" x2="160" y2="160" stroke="currentColor" stroke-width="2" class="animate-pulse" />
        </svg>
      </div>
    )}
  </div>
  
  <div class="absolute inset-x-0 h-[1px] bg-gradient-to-r from-transparent via-lime-400/40 to-transparent blur-sm z-30 animate-pulse"></div>
  <div class="absolute w-[1000px] h-[1000px] bg-emerald-500/10 rounded-full blur-[160px] -top-1/2 -left-1/4"></div>
  <div class="absolute w-[800px] h-[800px] bg-lime-500/5 rounded-full blur-[140px] -bottom-1/2 -right-1/4"></div>
</div>
