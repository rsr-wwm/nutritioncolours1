---
interface Props {
  subtitle: string;
  title: string;
  light?: boolean;
  isMain?: boolean;
}

const { subtitle, title, light = false, isMain = false } = Astro.props;
const HeadingTag = isMain ? 'h1' : 'h2';
---

<div class="relative z-10 text-center mb-10 space-y-4 px-4">
  <span class={light ? "text-lime-400 text-sm font-black uppercase tracking-[0.3em]" : "badge-clinical"}>
    {subtitle}
  </span>
  <HeadingTag class={`text-4xl md:text-6xl lg:text-7xl font-black brand-font leading-tight ${light ? 'text-white' : 'text-emerald-950'}`}>
    {title}
  </HeadingTag>
  <div class="flex justify-center mt-4">
    <div class={`w-16 md:w-24 h-1.5 rounded-full ${light ? 'bg-lime-400' : 'bg-gradient-to-r from-emerald-500 to-lime-500'}`}></div>
    <div class={`w-3 md:w-4 h-1.5 rounded-full ml-2 ${light ? 'bg-white/50' : 'bg-teal-400'}`}></div>
  </div>
</div>
