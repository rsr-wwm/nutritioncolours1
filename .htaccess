# NutritionColours — Apache/Hostinger config for the static build.
# Deployed to /public_html/.htaccess (Astro copies public/ to the site root).
# Scope is deliberately minimal + additive: it wires the custom 404 and 301s a
# curated set of plausible/invented paths to real pages. It does NOT rewrite any
# existing valid route. Test on staging before production.

# --- Custom 404 (MRS §7) ----------------------------------------------------
# Serve the designed recovery page instead of Apache's default on any dead URL.
ErrorDocument 404 /404.html

# --- Legacy _astro Redirect (MRS §12) ---------------------------------------
# Transparently redirect any legacy search engine crawler or cached URL looking for
# `/_astro/` to `/assets/` to guarantee zero 404s in Google Search Console.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^_astro/(.*)$ /assets/$1 [R=301,L]
</IfModule>

# --- Pre-compressed Static Asset Negotiation (Brotli / Gzip) -----------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Serve Brotli pre-compressed CSS/JS if client supports br
  RewriteCond %{HTTP:Accept-Encoding} br
  RewriteCond %{REQUEST_FILENAME}\.br -s
  RewriteRule ^(.*)\.(css|js|svg)$ $1\.$2\.br [QSA,L]

  # Serve Gzip pre-compressed CSS/JS if client supports gzip
  RewriteCond %{HTTP:Accept-Encoding} gzip
  RewriteCond %{REQUEST_FILENAME}\.gz -s
  RewriteRule ^(.*)\.(css|js|svg)$ $1\.$2\.gz [QSA,L]
</IfModule>

# --- Correct Content Encoding for Pre-compressed Static Files ---------------
<FilesMatch "\.css\.br$">
  Header set Content-Encoding br
  Header set Content-Type "text/css; charset=utf-8"
</FilesMatch>
<FilesMatch "\.js\.br$">
  Header set Content-Encoding br
  Header set Content-Type "application/javascript; charset=utf-8"
</FilesMatch>
<FilesMatch "\.svg\.br$">
  Header set Content-Encoding br
  Header set Content-Type "image/svg+xml; charset=utf-8"
</FilesMatch>
<FilesMatch "\.css\.gz$">
  Header set Content-Encoding gzip
  Header set Content-Type "text/css; charset=utf-8"
</FilesMatch>
<FilesMatch "\.js\.gz$">
  Header set Content-Encoding gzip
  Header set Content-Type "application/javascript; charset=utf-8"
</FilesMatch>
<FilesMatch "\.svg\.gz$">
  Header set Content-Encoding gzip
  Header set Content-Type "image/svg+xml; charset=utf-8"
</FilesMatch>

# --- Immutable Cache Headers for Assets (Astro & Media) -----------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|png|jpg|jpeg|svg|woff2?|br|gz|zstd)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# --- Hallucinated-URL capture (MRS §42.6) -----------------------------------
# LLMs (ChatGPT/Perplexity/Gemini) invent plausible URLs on your domain; users
# also guess short paths. Each line converts a likely-invented/guessed path into
# a 301 to the closest real page, turning the model's imagination into traffic.
#
# HOW TO EXTEND: weekly, grep server logs for 404s whose user-agent or referrer is
# an AI bot/engine (GPTBot, ClaudeBot, PerplexityBot, chatgpt.com, perplexity.ai),
# find the closest real page, and add a `Redirect 301 /invented /real` line below.
#
# All targets below were verified to exist in the build.

# Section shortcuts people/AI guess (we relabeled "Health Topics" as "Diseases")
Redirect 301 /diseases            /knowledge/diseases
Redirect 301 /disease             /knowledge/diseases
Redirect 301 /conditions          /knowledge/diseases
Redirect 301 /condition           /knowledge/diseases
Redirect 301 /herbs               /knowledge/herbs
Redirect 301 /herbs-and-spices    /knowledge/herbs
Redirect 301 /spices              /knowledge/spices
Redirect 301 /glossary            /knowledge
Redirect 301 /blog                /knowledge
Redirect 301 /blogs               /knowledge
Redirect 301 /articles            /knowledge
Redirect 301 /nutrigenomics       /knowledge
Redirect 301 /genomics            /knowledge
Redirect 301 /drug-interactions   /knowledge
Redirect 301 /interactions        /knowledge
Redirect 301 /vegan               /knowledge
Redirect 301 /knowledge-base      /knowledge
Redirect 301 /knowledge/health-topics      /knowledge/diseases
# /tools (interactive calculators/diagnostics) retired 2026-07-19 — client-side tool components removed to cut JS/resource cost.
Redirect 301 /tools               /knowledge
Redirect 301 /calculators         /knowledge
Redirect 301 /calculator          /knowledge
Redirect 301 /knowledge/health-conditions    /knowledge/diseases

# === Health-Topics -> Diseases pillar merge (2026-07-19) ===
# The 454 'health topics' pages were mis-routed into /knowledge/foods/general-nutrition/general-science/*.
# Owner ruling: Diseases = Health Topics = Health Conditions (one pillar). These 301s move the old
# foods-bucket URLs to their new canonical /knowledge/diseases/... homes.
