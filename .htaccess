# --- Browser & CDN Caching (LiteSpeed/Apache mod_expires) --------------------
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Default caching rule (2 days)
  ExpiresDefault "access plus 2 days"
  
  # Static assets - CSS and JS (content-hashed by Astro, safe to cache long-term)
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  
  # Media assets (images, icons, vectors)
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # Font files
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

# --- Cache-Control Headers (LiteSpeed/Apache mod_headers) -------------------
<IfModule mod_headers.c>
  # 1. Content-hashed static assets (CSS, JS, Fonts) - cache forever, never revalidate
  <FilesMatch "\.(css|js|woff|woff2|otf|ttf)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  # 2. Media assets (images, icons) - cache long-term
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>

  # 3. HTML & API responses - must validate before serving (instant updates after deploy)
  <FilesMatch "\.(html|xml|json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
