---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icons from '../../components/Icons.astro';
import SharedSections from '../../components/SharedSections.astro';
import Accordion from '../../components/Accordion.astro';
import { RECIPES } from '../../data/recipes';
import { RECIPE_SPECIFIC_FAQS } from '../../data/constants';
import { getFaqPageSchema } from '../../lib/seo/entityGraph';

export async function getStaticPaths() {
  return RECIPES.map((recipe) => ({
    params: { recipe_id: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;

// getAeoSnippet helper migrated for static layout
function getAeoSnippet(customSnippet?: string, fallbackText?: string): string {
  if (customSnippet && customSnippet.trim()) return customSnippet;
  if (!fallbackText) return '';
  const sentences = fallbackText.split(/[.!?]\s+/);
  if (sentences.length >= 2) {
    const firstTwo = fallbackText.substring(0, sentences[0].length + sentences[1].length + 4).trim();
    if (firstTwo.split(/\s+/).length <= 45) return firstTwo;
  }
  const words = fallbackText.split(/\s+/);
  if (words.length <= 35) return fallbackText;
  return words.slice(0, 35).join(' ') + '...';
}

const recipeSchema = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  "name": recipe.title,
  "description": recipe.description,
  "author": {
    "@type": "Person",
    "name": recipe.preparedBy || "Dr. Shilpa Thakur"
  },
  "calories": `${recipe.calories} KCAL`,
  "recipeCategory": recipe.category,
  "recipeIngredient": recipe.ingredients || [],
  "recipeInstructions": recipe.instructions || []
};

// The FAQ section below is already real, server-rendered HTML (Accordion) — this
// schema is the standard extra step for FAQ rich-result eligibility, not fixing a
// visibility gap.
const recipeFaqPageSchema = getFaqPageSchema(`/recipe/${recipe.id}`, RECIPE_SPECIFIC_FAQS[recipe.id]);
---

<BaseLayout 
  title={`${recipe.title} | Metabolic Nutrition Recipe`}
  description={`Dr. Shilpa Thakur's clinical protocol for ${recipe.title}. Glycemic load: ${recipe.glycemicLoad || 'Low'}, Prepared by: ${recipe.preparedBy}.`}
  keywords={[recipe.category, "Metabolic Recipe", recipe.title]}
>
  {/* Dynamic JSON-LD Schema */}
  <script type="application/ld+json" set:html={JSON.stringify(recipeSchema)} />
  {recipeFaqPageSchema && <script type="application/ld+json" set:html={recipeFaqPageSchema} />}

  <div class="min-h-screen bg-stone-50/30 pb-24 pt-24">
  <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-12 gap-12">
    <div class="lg:col-span-8 space-y-12">
      <div class="bg-white rounded-[48px] p-10 md:p-16 border border-stone-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-50 rounded-bl-full opacity-50" aria-hidden="true"></div>
        <div class="space-y-8 relative z-10">
          <div class="flex flex-wrap gap-4 items-center">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border border-stone-100 bg-white shadow-sm">
              <span>📄</span>
              <span class="text-xs font-black uppercase tracking-widest text-stone-600">Protocol</span>
            </span>
            {recipe.tags.map((tag: string) => (
              <span class="text-[9px] font-black uppercase tracking-widest text-emerald-800 bg-emerald-50 px-3 py-1 rounded-full border border-emerald-200">{tag}</span>
            ))}
          </div>
          <h1 class="text-4xl md:text-7xl font-black text-emerald-950 brand-font leading-[0.85] tracking-tighter">{recipe.title}</h1>
          <p class="text-xl text-stone-500 leading-relaxed font-medium italic border-l-4 border-lime-400 pl-8 max-w-2xl">{recipe.description}</p>
          <div class="p-6 bg-emerald-50 rounded-3xl border border-emerald-100/50 space-y-2 mt-4">
            <span class="text-[10px] font-black uppercase tracking-widest text-emerald-800 block">Direct Answer Summary</span>
            <dfn class="not-italic text-sm text-stone-600 block leading-relaxed font-semibold">
              {getAeoSnippet(recipe.aeoDirectSnippet, recipe.healingDescription)}
            </dfn>
          </div>
          <div class="grid md:grid-cols-3 gap-6 pt-10 border-t border-stone-50">
            <div class="space-y-1">
              <span class="text-[10px] font-black text-stone-500 uppercase tracking-widest">Metabolic Load</span>
              <p class="text-xl font-black text-emerald-990 brand-font">{recipe.calories} KCAL</p>
            </div>
            <div class="space-y-1">
              <span class="text-[10px] font-black text-stone-500 uppercase tracking-widest">Protocol Timing</span>
              <p class="text-xl font-black text-emerald-990 brand-font">{recipe.prepTime}</p>
            </div>
            <div class="space-y-1">
              <span class="text-[10px] font-black text-stone-500 uppercase tracking-widest">Primary Objective</span>
              <p class="text-xs font-black text-emerald-700 uppercase tracking-tight leading-tight pt-1">{recipe.primaryBenefit}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <section class="bg-white rounded-[40px] p-10 border border-stone-100 shadow-sm space-y-8 h-fit">
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-black text-emerald-950 brand-font uppercase">Chemical Components</h3>
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border border-stone-100 bg-white shadow-sm">
              <span>🌿</span>
              <span class="text-xs font-black uppercase tracking-widest text-stone-600">Nutrition</span>
            </span>
          </div>
          <div class="space-y-3">
            {recipe.ingredients.map((ing: any) => (
              <div class="flex justify-between items-center py-3 border-b border-stone-50 last:border-0">
                <span class="font-bold text-stone-700 text-sm">{ing.name}</span>
                <span class="text-xs font-mono font-black text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded">{ing.detail}</span>
              </div>
            ))}
          </div>
        </section>
        <section class="bg-emerald-950 rounded-[40px] p-10 text-white relative overflow-hidden flex flex-col h-full">
          <div class="absolute top-0 right-0 w-32 h-32 bg-lime-400/20 rounded-full blur-3xl opacity-50" aria-hidden="true"></div>
          <div class="relative z-10 space-y-8 flex-grow">
            <h3 class="text-xl font-black brand-font uppercase text-lime-400">Metabolic Mechanism</h3>
            <p class="text-emerald-100/70 text-lg leading-relaxed italic">{recipe.healingDescription}</p>
            <div class="space-y-6 pt-6 border-t border-white/10">
              {(recipe.fullHealingContent || '').split('\n\n').map((chunk: string) => {
                const parts = chunk.split(':');
                const title = parts[0];
                const rest = parts.slice(1).join(':').trim();
                return (
                  <div class="space-y-1">
                    <div class="text-[10px] font-black uppercase tracking-widest text-lime-400">{title}</div>
                    <p class="text-xs text-white/70 leading-relaxed">{rest}</p>
                  </div>
                );
              })}
            </div>
          </div>
        </section>
      </div>
      {RECIPE_SPECIFIC_FAQS[recipe.id] && (
        <section class="bg-white rounded-[40px] p-10 border border-stone-100 shadow-sm space-y-8">
          <div class="flex items-center justify-between border-b border-stone-50 pb-6">
            <h3 class="text-xl font-black text-emerald-950 brand-font uppercase">Optimization Protocol</h3>
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border border-stone-100 bg-white shadow-sm">
              <span>🧪</span>
              <span class="text-xs font-black uppercase tracking-widest text-stone-600">Clinical</span>
            </span>
          </div>
          <div class="grid gap-4">
            {RECIPE_SPECIFIC_FAQS[recipe.id].map((faq: any) => (
              <Accordion title={faq.question} content={faq.answer} category="Recipe Specific" />
            ))}
          </div>
        </section>
      )}
    </div>
    <aside class="lg:col-span-4 space-y-8">
      <div class="bg-white rounded-[40px] p-8 border border-stone-100 shadow-xl overflow-hidden relative">
        <div class="absolute top-0 right-0 p-8 opacity-[0.03] rotate-12" aria-hidden="true">
          <Icons name="flask" size={160} />
        </div>
        <div class="relative z-10 space-y-8">
          <div class="space-y-2">
            <span class="text-[9px] font-black text-emerald-800 uppercase tracking-[0.3em]">Validation Status</span>
            <h3 class="text-2xl font-black text-emerald-950 brand-font tracking-tight">Active Protocol</h3>
          </div>
          <div class="flex items-center gap-4 p-6 bg-emerald-50 rounded-2xl border border-emerald-100">
            <div class="w-12 h-12 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600">
              <Icons name="check" size={20} />
            </div>
            <div>
              <p class="text-[10px] font-black text-stone-600 uppercase tracking-widest">Protocol Architect</p>
              <p class="text-sm font-black text-emerald-950 uppercase tracking-tight leading-tight">{recipe.preparedBy}</p>
            </div>
          </div>
          <div class="p-6 bg-stone-50 rounded-2xl border border-stone-100 space-y-4">
            <div class="text-xs font-black uppercase tracking-widest text-emerald-800 border-b border-stone-200 pb-2">Clinical Parameters</div>
            <div class="space-y-3">
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider">
                <span class="text-stone-500">Glycemic Load</span>
                <span class="text-emerald-700">Low</span>
              </div>
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider">
                <span class="text-stone-500">Inflammation Index</span>
                <span class="text-emerald-700">Anti-Inflammatory</span>
              </div>
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider">
                <span class="text-stone-400">Mineral Density</span>
                <span class="text-emerald-700">High</span>
              </div>
            </div>
          </div>
          <a href="/plans" class="w-full bg-emerald-900 !text-white !no-underline font-bold uppercase tracking-widest text-[10px] py-4 rounded-xl hover:bg-emerald-800 transition-all flex items-center justify-center gap-2 text-center block">
            <span class="!text-white !no-underline flex items-center justify-center gap-2">
              Clinical Enrollment <Icons name="arrow-right" size={14} class="inline-block ml-1" />
            </span>
          </a>
        </div>
      </div>
      <div class="space-y-6">
        <div class="text-xs font-black uppercase tracking-[0.3em] text-stone-600 pl-4 border-l-2 border-lime-400">Complementary Protocols</div>
        <div class="space-y-4">
          {RECIPES.filter((r) => r.id !== recipe.id).slice(0, 3).map((related) => (
            <a href={`/recipe/${related.id}`} class="bg-white p-6 rounded-3xl border border-stone-100 hover:border-emerald-200 transition-all cursor-pointer group flex items-center gap-4 block">
              <div class="w-12 h-12 rounded-xl bg-stone-50 flex items-center justify-center text-emerald-600 group-hover:bg-emerald-600 group-hover:text-white transition-all shadow-sm">
                <Icons name="utensils" size={18} />
              </div>
              <div>
                <h5 class="text-[11px] font-black text-emerald-950 uppercase group-hover:text-emerald-700 transition-colors leading-tight line-clamp-1">{related.title}</h5>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-[9px] font-bold text-stone-600 uppercase tracking-widest">{related.category}</span>
                  <div class="w-1 h-1 rounded-full bg-stone-200"></div>
                  <span class="text-[9px] font-bold text-emerald-800 tracking-widest uppercase">{related.calories} KCAL</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </aside>
  </div>
</div>
</BaseLayout>
