---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TeamMemberProfile } from '../../components/TeamMemberProfile';
import { TEAM } from '../../lib/constants';

export async function getStaticPaths() {
  return TEAM.map((member) => ({
    params: { id: member.slug || member.id },
    props: { member },
  }));
}

const { member } = Astro.props;

const SITE_URL = (Astro.site || 'https://nutritioncolours.com').toString().replace(/\/$/, '');
const memberSameAs = member.socials ? Object.values(member.socials).filter(Boolean) : [];
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE_URL}/team/${member.slug || member.id}#person`,
  "name": member.name,
  "jobTitle": member.role,
  "description": member.bio,
  "url": `${SITE_URL}/team/${member.slug || member.id}`,
  "image": `${SITE_URL}${member.image}`,
  "worksFor": { "@id": `${SITE_URL}/#organization` },
  ...(memberSameAs.length > 0 && { "sameAs": memberSameAs }),
};
---

<BaseLayout
  title={`${member.name} - ${member.role} | NutritionColours Team`}
  description={`${member.name} is a specialist in ${member.role} at NutritionColours Clinic.`
  }
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <TeamMemberProfile client:load member={member} navigate={(path) => window.location.href = '/' + path} />
</BaseLayout>
