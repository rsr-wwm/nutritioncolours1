---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { HealthTopicPage as ArticleClientPage } from '../../components/HealthTopicPage';
import { BLOG_ARTICLES } from '../../lib/constants';

export async function getStaticPaths() {
  return BLOG_ARTICLES.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<BaseLayout
  title={`${article.title} | NutritionColours`}
  description={article.title}
  keywords={[article.category, "Metabolic Article", article.title]}
>
  <ArticleClientPage
    client:load
    topicId={article.id}
    navigate={(path: string) => { window.location.href = '/' + path; }}
  />
</BaseLayout>
