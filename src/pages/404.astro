---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icons from '../components/Icons.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { TOPICS } from '../data/topics';

// A handful of high-traffic destinations to route lost visitors (and crawlers) back
// into the site instead of leaving them at a dead end.
const popularTopics = TOPICS.slice(0, 6);
---

<BaseLayout
  title="Page Not Found | NutritionColours"
  description="The page you're looking for doesn't exist. Explore our clinical nutrition topics, programs, and resources instead."
>
  <div class="max-w-4xl mx-auto px-6 py-24 text-center space-y-12">
    <div class="space-y-6">
      <span class="text-emerald-700 font-black uppercase tracking-[0.3em] text-xs">Error 404</span>
      <h1 class="text-4xl md:text-6xl font-black text-emerald-950 brand-font">This page took a wrong turn.</h1>
      <p class="text-stone-500 max-w-xl mx-auto leading-relaxed">
        We couldn't find the page you were looking for. It may have been moved, renamed, or never existed.
        Here are a few places to get back on track.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-4">
      <a href="/" class="bg-emerald-900 px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-emerald-800 transition-all flex items-center gap-2">
        <span class="btn-cta-text-white flex items-center gap-2">
          <Icons name="arrow-right" size={14} /> Back to Home
        </span>
      </a>
      <a href="/knowledge/health-topics" class="bg-stone-100 px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-emerald-50 hover:text-emerald-700 transition-all">
        Browse Health Topics
      </a>
      <a href="/plans" class="bg-stone-100 px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-emerald-50 hover:text-emerald-700 transition-all">
        View Clinical Plans
      </a>
    </div>

    <div class="pt-8 border-t border-stone-100">
      <SectionHeading subtitle="Popular Destinations" title="Explore Clinical Topics" isMain={false} />
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-8 text-left">
        {popularTopics.map((topic) => (
          <a href={`/topic/${topic.id}`} class="bg-white border border-stone-100 p-5 rounded-2xl hover:border-emerald-200 hover:shadow-lg transition-all group block">
            <h2 class="text-xs font-black text-emerald-950 uppercase tracking-tight leading-tight group-hover:text-emerald-700 transition-colors">{topic.title}</h2>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
