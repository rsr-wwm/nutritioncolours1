---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icons from '../../components/Icons.astro';
import SharedSections from '../../components/SharedSections.astro';
import AnimatedVisual from '../../components/AnimatedVisual.astro';
import { PLANS, PLANS_FAQS } from '../../data/constants';
import { getDynamicCategoryFaqs } from '../../lib/faqHelper'; // Stays as a utility helper

export async function getStaticPaths() {
  return [
    { params: { slug: 'metabolic-mastery' }, props: { planId: 'plan-1' } },
    { params: { slug: 'therapeutic-reversal' }, props: { planId: 'plan-2' } },
    { params: { slug: 'cellular-resurrection' }, props: { planId: 'plan-3' } },
  ];
}

const { slug } = Astro.params;
const { planId } = Astro.props;

const selectedPlan = PLANS.find((p) => p.id === planId);
if (!selectedPlan) {
  throw new Error(`Plan not found: ${slug}`);
}

const specificFaqs = getDynamicCategoryFaqs(`plans/${slug}`, null);

const SITE_URL = (Astro.site || 'https://nutritioncolours.com').toString().replace(/\/$/, '');
// Real published tiers/prices from PLANS data — not invented figures.
const planOffers = (selectedPlan.tiers || []).map((tier) => ({
  "@type": "Offer",
  "name": `${selectedPlan.name} — ${tier.label}`,
  "priceCurrency": "INR",
  "price": tier.price.replace(/[^\d]/g, ''),
  "availability": "https://schema.org/InStock",
}));

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${SITE_URL}/plans/${slug}#service`,
  "name": selectedPlan.name,
  "description": selectedPlan.description,
  "provider": { "@id": `${SITE_URL}/#organization` },
  ...(planOffers.length > 0 && {
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": `${selectedPlan.name} Pricing`,
      "itemListElement": planOffers,
    },
  }),
  "areaServed": "IN"
};
---

<BaseLayout 
  title={`${selectedPlan.name} | Clinical Reversal Program`}
  description={`${selectedPlan.description}. Duration: ${selectedPlan.duration || 'Flexible'}. Focused on root-cause metabolic healing.`}
  keywords={[selectedPlan.name, "Metabolic Reversal", "Dr. Shilpa Thakur Plan"]}
>
  {/* Dynamic JSON-LD Schema */}
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <div class="space-y-0">
  <div class="relative w-full min-h-[500px] lg:h-[70vh] bg-emerald-950 overflow-hidden flex items-center px-6">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-[radial-gradient(#10b981_1px,transparent_1px)] [background-size:48px_48px] opacity-10" aria-hidden="true"></div>
      <AnimatedVisual type={selectedPlan.id} />
      <div class="absolute inset-0 bg-gradient-to-r from-emerald-950 via-emerald-950/90 to-emerald-950/40" aria-hidden="true"></div>
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-emerald-950 to-transparent" aria-hidden="true"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto w-full grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-3 px-6 py-2 rounded-full bg-lime-400/10 border border-lime-400/20 text-lime-400 text-xs font-black uppercase tracking-[0.5em]">
          <Icons name="flask" size={16} /> Precision Protocol
        </div>
        <div class="space-y-6">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white brand-font leading-[0.9] tracking-tighter">{selectedPlan.name}</h1>
          <div class="w-24 h-1.5 bg-lime-400 rounded-full" aria-hidden="true"></div>
        </div>
        <p class="text-emerald-50/80 text-xl md:text-2xl font-bold italic leading-relaxed border-l-4 border-lime-400 pl-8">{selectedPlan.description}</p>
        <div class="flex gap-4">
          <a href="/plans" class="bg-white/10 hover:bg-white/20 px-8 py-4 rounded-xl border border-white/10 text-xs font-black uppercase tracking-widest transition-all flex items-center gap-3">
            <Icons name="arrow-right" size={16} class="rotate-180" /> 
            <span class="btn-cta-text-white">Back to Catalog</span>
          </a>
        </div>
      </div>
      <div class="hidden lg:block relative">
        <div class="absolute -inset-4 bg-lime-400/20 blur-3xl rounded-full" aria-hidden="true"></div>
        <div class="relative bg-white/5 backdrop-blur-2xl border border-white/10 rounded-[48px] p-12 overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-lime-400/5 to-emerald-400/5" aria-hidden="true"></div>
          <Icons name="flask" size={120} class="text-lime-400/20 absolute -bottom-10 -right-10 group-hover:scale-110 transition-transform duration-1000" />
          <div class="relative z-10 space-y-6">
            <div class="w-16 h-16 rounded-2xl bg-lime-400 text-emerald-950 flex items-center justify-center shadow-lg shadow-lime-400/20">
              <Icons name="lock" size={32} />
            </div>
            <h3 class="text-3xl font-black text-white brand-font">Protocol Admission</h3>
            <a href="/contact" class="w-full bg-white py-4 rounded-2xl font-black uppercase tracking-widest text-xs hover:bg-lime-400 transition-all cursor-pointer text-center block">
              <span class="btn-cta-text-dark">Secure Early Slot</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-6 py-20">
    <div class="bg-white rounded-[40px] shadow-2xl border border-stone-100 overflow-hidden">
      <div class="grid md:grid-cols-2">
        <div class="p-10 md:p-16 border-r border-stone-100 bg-stone-50/30">
          <h3 class="text-2xl font-black text-emerald-950 mb-8 brand-font flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-emerald-900 text-white flex items-center justify-center">
              <Icons name="check" size={20} />
            </div>
            Core Protocol Benefits
          </h3>
          <div class="space-y-6">
            {selectedPlan.features.map((f: string) => (
              <div class="flex gap-4 group">
                <div class="w-6 h-6 rounded-full bg-white border border-emerald-100 flex items-center justify-center shrink-0 group-hover:bg-emerald-600 group-hover:text-white transition-all">
                  <Icons name="check" size={14} class="text-emerald-600 group-hover:text-white transition-colors" />
                </div>
                <p class="text-stone-700 font-medium leading-relaxed">{f}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="p-10 md:p-16 space-y-10">
          <div>
            <h3 class="text-2xl font-black text-emerald-950 mb-6 brand-font">Investment Tiers</h3>
            <div class="grid gap-6">
              {selectedPlan.tiers.map((t: any) => (
                <div class="bg-white p-8 rounded-3xl border-2 border-stone-100 hover:border-emerald-500 transition-all group relative overflow-hidden">
                  <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity" aria-hidden="true">
                    <Icons name="flask" size={60} />
                  </div>
                  <div class="relative z-10 flex justify-between items-center">
                    <div>
                      <div class="text-xs font-black text-stone-500 uppercase tracking-widest mb-1">{t.label}</div>
                      <div class="text-3xl font-black text-emerald-700 brand-font">{t.price}</div>
                    </div>
                    <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600">
                      <Icons name="arrow-right" size={20} />
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="pt-6 border-t border-stone-100">
            <a href="/contact" class="w-full bg-emerald-900 py-6 rounded-2xl font-black uppercase tracking-widest text-sm hover:bg-emerald-800 transition-all shadow-xl shadow-emerald-900/20 flex items-center justify-center gap-4 group text-center block">
              <span class="btn-cta-text-white flex items-center justify-center">
                Secure Your Consultation <Icons name="arrow-right" size={20} class="group-hover:translate-x-1 transition-transform inline-block ml-2" />
              </span>
            </a>
            <p class="text-center text-stone-500 text-[10px] font-bold uppercase tracking-widest mt-6 italic">Program admission subject to clinical evaluation and initial screening.</p>
          </div>
        </div>
      </div>
      <div class="px-10 pb-6"><SharedSections type="disclaimer" /></div>
      <div class="p-10 border-t border-stone-100"><SharedSections type="faq" faqData={specificFaqs} faqTitle="Program Specific FAQs" /></div>
    </div>
    <SharedSections type="faq" faqData={PLANS_FAQS} faqTitle="Program FAQs" />
  </div>
</div>
</BaseLayout>

