---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { LocalDirectory as ClinicClientPage } from '../../components/LocalDirectory';
import { LOCATIONS_DATA } from '../../lib/locationsData';

export async function getStaticPaths() {
  const cities = [...new Set(LOCATIONS_DATA.map(l => l.city.toLowerCase().replace(/\s+/g, '-')))];
  return cities.map((id) => ({
    params: { id },
  }));
}

const { id } = Astro.params;

// NOTE: ClinicClientPage below renders with client:only, meaning Astro emits no HTML for it
// at build time — search/AI crawlers that don't execute JS previously saw a blank page here.
// The block below is a real, server-rendered summary from the same location data, so every
// one of these ~1,690 pages has genuine crawlable content independent of the client island.
const cityLocations = LOCATIONS_DATA.filter(l => l.city.toLowerCase().replace(/\s+/g, '-') === id);
const loc = cityLocations[0];
const cityLabel = id?.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()) || '';

const SITE_URL = (Astro.site || 'https://nutritioncolours.com').toString().replace(/\/$/, '');
// Honest schema for a remote/telehealth practice: this is service-area targeting, not a
// physical branch office, so we deliberately avoid LocalBusiness/MedicalClinic + invented
// street addresses (which would violate Google's guidelines for non-physical locations).
const clinicSchema = loc ? {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "@id": `${SITE_URL}/clinic/${id}#page`,
  "url": `${SITE_URL}/clinic/${id}`,
  "name": `Remote Clinical Nutrition Outreach — ${cityLabel}, ${loc.state}`,
  "about": {
    "@type": "Service",
    "name": "Remote Clinical Nutrition Consultation",
    "provider": { "@id": `${SITE_URL}/#organization` },
    "areaServed": {
      "@type": "City",
      "name": cityLabel,
      "containedInPlace": { "@type": "State", "name": loc.state }
    }
  },
  "publisher": { "@id": `${SITE_URL}/#organization` }
} : null;
---

<BaseLayout
  title={`Metabolic Clinic in ${cityLabel} | NutritionColours`}
  description={`Find metabolic health services, diagnostic labs, and consulting hours in ${cityLabel}.`}
  ogImage={`/og/clinic/${id}.png`}
>
  {clinicSchema && <script type="application/ld+json" set:html={JSON.stringify(clinicSchema)} />}

  {loc && (
    <div class="max-w-5xl mx-auto px-6 pt-8 pb-4">
      <div class="rounded-3xl border border-stone-100 bg-stone-50/50 p-8 space-y-4">
        <h2 class="text-2xl font-black text-emerald-950 brand-font">
          Metabolic Nutrition Outreach — {cityLabel}, {loc.state}
        </h2>
        <p class="text-stone-600 text-sm leading-relaxed max-w-3xl">
          NutritionColours provides remote clinical nutrition consultations serving {cityLabel} and the surrounding {loc.state} region ({loc.timezone}, dialing code {loc.dialingCode}, {loc.currency}). Common regional metabolic concerns in this area include {(loc.healthIssues || []).slice(0, 3).join(', ') || 'metabolic and lifestyle disorders'}, often addressed alongside locally available produce such as {(loc.localFruits || []).slice(0, 2).join(' and ')} and {(loc.localVegetables || []).slice(0, 2).join(' and ')}.
        </p>
        <p class="text-xs text-stone-400 uppercase tracking-widest font-bold">
          {cityLocations.length > 1 ? `${cityLocations.length} outreach records for this city` : 'Outreach region profile'} · Climate: {loc.weather}
        </p>
      </div>
    </div>
  )}

  <ClinicClientPage
    client:only="react"
    currentPath={`clinic/${id || ''}`}
    navigate={(path: string) => { window.location.href = '/' + path; }}
  />
</BaseLayout>
