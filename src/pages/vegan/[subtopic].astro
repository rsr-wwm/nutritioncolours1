---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icons from '../../components/Icons.astro';
import SharedSections from '../../components/SharedSections.astro';
import { TOPICS } from '../../data/topics';
import { VEGAN_SUB_TOPICS } from '../../lib/constants';

export async function getStaticPaths() {
  return VEGAN_SUB_TOPICS.map((topic) => ({
    params: { subtopic: topic.id },
  }));
}

const { subtopic } = Astro.params;
const topicKey = `vegan-${subtopic}`;
const topic = TOPICS.find((t) => t.id === topicKey);

if (!topic) {
  return Astro.redirect('/404');
}

// Helper to extract first two sentences for AEO
function getAeoSnippet(customSnippet?: string, fallbackText?: string): string {
  if (customSnippet && customSnippet.trim()) return customSnippet;
  if (!fallbackText) return '';
  const sentences = fallbackText.split(/[.!?]\s+/);
  if (sentences.length >= 2) {
    const firstTwo = fallbackText.substring(0, sentences[0].length + sentences[1].length + 4).trim();
    if (firstTwo.split(/\s+/).length <= 45) return firstTwo;
  }
  const words = fallbackText.split(/\s+/);
  if (words.length <= 35) return fallbackText;
  return words.slice(0, 35).join(' ') + '...';
}

const topicSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalCondition",
  "name": topic.title,
  "description": topic.shortDesc || topic.solution,
  "possibleTreatment": [
    {
      "@type": "MedicalTherapy",
      "name": "Circadian Nutrition Optimization"
    }
  ]
};
---

<BaseLayout 
  title={topic.pageTitle || `${topic.title} | Clinical Protocol`}
  description={topic.metaDescription || topic.shortDesc}
  keywords={[topic.primaryKeyword || topic.title, "Vegan Protocol", "NutritionColours"]}
>
  <script type="application/ld+json" set:html={JSON.stringify(topicSchema)} />

  <div class="animate-in fade-in duration-1000 bg-white">
    <div class="max-w-7xl mx-auto px-6 pt-32 pb-4">
      <a href="/knowledge/vegan" class="inline-flex items-center gap-2 text-xs font-black text-emerald-800 uppercase tracking-widest hover:text-emerald-950 transition-colors">← Back to Vegan Guide</a>
    </div>

    <div class="space-y-20 pb-20 bg-white">
      {/* Scientific Dossier Hero */}
      <div class="bg-emerald-950 pt-20 pb-24 px-6 relative overflow-hidden">
        <div class="absolute inset-0 opacity-10 pointer-events-none">
          <div class="absolute top-0 right-0 w-full h-full bg-[radial-gradient(#10b981_1px,transparent_1px)] [background-size:32px_32px] [mask-image:linear-gradient(to_bottom,black,transparent)]"></div>
        </div>
        
        <div class="max-w-7xl mx-auto grid lg:grid-cols-12 gap-16 items-center relative z-10">
          <div class="lg:col-span-8 space-y-8 text-white">
            <div class="flex items-center gap-4">
               <div class="h-px w-8 bg-lime-400"></div>
               <span class="text-xs font-black uppercase tracking-[0.4em] text-lime-400">Clinical Protocol</span>
            </div>
            
            <h1 class="text-4xl md:text-7xl font-black brand-font leading-[0.9] tracking-tighter">
              {topic.title}
            </h1>
            
            <div class="p-8 bg-emerald-900/40 backdrop-blur-md rounded-[32px] border border-white/5 space-y-4">
               <p class="text-xl md:text-2xl text-emerald-100 font-medium italic leading-relaxed border-l-2 border-lime-400/30 pl-6">
                 {topic.shortDesc}
               </p>
               
               <div class="border-t border-white/10 pt-4 mt-4">
                 <span class="text-[10px] font-black uppercase tracking-widest text-lime-400 mb-1 block">Direct Answer Summary</span>
                 <dfn class="not-italic text-sm text-emerald-50 block leading-relaxed">
                   {getAeoSnippet(topic.aeoDirectSnippet, topic.fullContent || topic.solution)}
                 </dfn>
               </div>
            </div>
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-12 gap-16">
        <div class="lg:col-span-8 space-y-12">
          <div class="grid md:grid-cols-2 gap-6">
            <div class="p-8 bg-stone-50 rounded-[32px] border border-stone-100 relative group overflow-hidden">
              <h2 class="text-xs font-black uppercase tracking-widest text-stone-400 mb-4 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-red-400"></span> The Core Problem
              </h2>
              <p class="text-stone-700 font-medium leading-relaxed">
                {topic.problem}
              </p>
            </div>
            <div class="p-8 bg-emerald-50 rounded-[32px] border border-emerald-100 relative group overflow-hidden">
              <h2 class="text-xs font-black uppercase tracking-widest text-emerald-600 mb-4 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-emerald-400"></span> The Clinical Solution
              </h2>
              <p class="text-emerald-950 font-medium leading-relaxed">
                {topic.solution}
              </p>
            </div>
          </div>

          {topic.expandedSections && topic.expandedSections.length > 0 && (
            <div class="space-y-12">
              {topic.expandedSections.map((sect) => (
                <section class="space-y-6">
                  <h2 class="text-3xl font-black text-emerald-950 brand-font border-l-4 border-lime-400 pl-6">
                    {sect.heading}
                  </h2>
                  <p class="text-stone-700 leading-relaxed font-medium">
                    {sect.body}
                  </p>
                  {sect.listItems && sect.listItems.length > 0 && (
                    <div class="p-6 bg-stone-50 rounded-3xl border border-stone-100 space-y-4">
                      {sect.listTitle && (
                        <h3 class="text-xs font-black uppercase tracking-widest text-emerald-700">{sect.listTitle}</h3>
                      )}
                      <ul class="space-y-3">
                        {sect.listItems.map((li) => (
                          <li class="text-sm font-bold text-stone-700 flex items-start gap-3">
                            <span class="text-emerald-800 shrink-0 mt-0.5">•</span>
                            <span>{li}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                  {sect.proTip && (
                    <div class="p-6 bg-emerald-50/50 rounded-3xl border border-emerald-100/50">
                      <span class="text-[10px] font-black uppercase tracking-widest text-emerald-800 block mb-1">Dr. Shilpa's Pro Tip</span>
                      <p class="text-sm font-bold text-emerald-950 leading-relaxed italic">{sect.proTip}</p>
                    </div>
                  )}
                </section>
              ))}
            </div>
          )}

          {topic.naturalApproach && (
            <section class="bg-emerald-950 rounded-[40px] p-10 text-white relative overflow-hidden">
              <h2 class="text-xl font-black brand-font mb-8 flex items-center gap-3">
                Key Takeaways
              </h2>
              <div class="grid md:grid-cols-2 gap-4">
                {topic.naturalApproach.map((item) => (
                  <div class="flex items-center gap-4 bg-white/5 p-4 rounded-2xl border border-white/10 hover:bg-white/10 transition-colors">
                    <span class="text-sm font-bold uppercase tracking-wide">{item}</span>
                  </div>
                ))}
              </div>
            </section>
          )}
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 pb-20">
      <SharedSections type="disclaimer" />
    </div>
  </div>
</BaseLayout>
